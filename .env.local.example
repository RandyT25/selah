# =============================================================
# SELAH - Bible Application
# Environment Variables - Copy this file to .env.local
# =============================================================

# -------------------
# SUPABASE
# -------------------
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# -------------------
# APP
# -------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Selah

# -------------------
# BIBLE API
# API.Bible - Get your key at https://scripture.api.bible
# -------------------
BIBLE_API_KEY=your_api_bible_key
NEXT_PUBLIC_DEFAULT_BIBLE_ID=de4e12af7f28f599-02

# -------------------
# AI PROVIDER (OpenAI by default)
# -------------------
OPENAI_API_KEY=your_openai_api_key
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini

# -------------------
# AUDIO BIBLE
# Using YouVersion / Bible.is API
# -------------------
FAITHLIFE_API_KEY=your_faithlife_api_key

# -------------------
# ANALYTICS (Optional)
# -------------------
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# -------------------
# EMAIL (Supabase handles auth emails)
# Resend for transactional emails
# -------------------
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=noreply@selahapp.com

# -------------------
# PUSH NOTIFICATIONS (Optional)
# -------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# -------------------
# ADMIN
# -------------------
ADMIN_SECRET=your_admin_secret_key
